APP_NAME=LaravelAuthTemplate
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel_auth_template
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_pass
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="Laravel Auth Template"

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT=8
GEMINI_CONNECT_TIMEOUT=3

# Product export
PRODUCT_EXPORT_USD_RATE=26295.55
PRODUCT_EXPORT_RUN_INLINE=false
PRODUCT_EXPORT_AI_TRANSLATION=true
PRODUCT_EXPORT_CHUNK_ROWS=20
PRODUCT_EXPORT_CHUNK_SECONDS=45
PRODUCT_EXPORT_FALLBACK_CHUNK_ROWS=3
PRODUCT_EXPORT_FALLBACK_CHUNK_SECONDS=8
